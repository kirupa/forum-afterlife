# ============================================================
# 论坛配置 / Forum Configuration
# ============================================================

# Discourse 论坛域名（默认: cax.do）
FORUM_DOMAIN=cax.do

# Discourse API 密钥
# 获取方式: Discourse 管理后台 > 设置 > API > API Keys
DISCOURSE_API_KEY=your_discourse_api_key_here

# Webhook 验证密钥（必须与 Discourse 中设置的一致）
DISCOURSE_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================
# OpenAI 配置 / OpenAI Configuration
# ============================================================

# OpenAI API 密钥
OPENAI_API_KEY=sk-your-openai-api-key-here

# 模型层级配置（可选，使用默认值）
# 轻量级任务（S）: gpt-4o-mini
MODEL_TIER_S=gpt-4o-mini

# 中等任务（M）: gpt-4-turbo
MODEL_TIER_M=gpt-4-turbo

# 高级任务（L）: gpt-4o
MODEL_TIER_L=gpt-4o

# ============================================================
# 本地配置 / Local Configuration
# ============================================================

# 本地服务器基础 URL（可选）
# 如果不设置，将自动推断 HTTPS/HTTP 和主机名
KONVO_LOCAL_BASE_URL=https://cax.do/konvo

# 时区设置（可选）
KONVO_TIMEZONE=Asia/Shanghai

# 外部通知 Webhook（可选）
# 用于将机器人活动发送到其他系统
KONVO_NOTIFY_WEBHOOK=
